REQUIRE_AUTH=true
HOST=127.0.0.1
PORT=2048
JWT_SECRET=change-this-secret
PARENT_TOKEN_TTL=7d
DEVICE_TOKEN_TTL=365d
PAIRING_TTL_MINUTES=5
DATA_FILE=data/store.json
CONTENT_STORAGE=postgres
MEDIA_ROOT=media
MAX_VIDEO_UPLOAD_MB=2048
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
TRANSCODER_ENABLED=true
OTP_TTL_MINUTES=10
OTP_DEFAULT_CODE=
OTP_DEBUG=false
SMTP_SECURE=false

# Legacy /api/v1 PostgreSQL API
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/astir
# Remote PostgreSQL hosts use SSL automatically. Set DATABASE_SSL=false only if that host does not support SSL.
DATABASE_SSL=
DATABASE_SSL_REJECT_UNAUTHORIZED=false
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=change-me
SUPER_ADMIN_NAME=Super Admin
MEDIA_SIGNING_SECRET=astir-local-media-secret

# Legacy integrations. Missing values make provider endpoints return 503.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
FIREBASE_SERVER_KEY=
FIREBASE_API_URL=https://fcm.googleapis.com/fcm/send
# Comma-separated OAuth client IDs accepted in Google ID token aud.
GOOGLE_CLIENT_IDS=
# Backward-compatible alias still accepted by the backend.
GOOGLE_CLIENT_ID=
# Comma-separated app Bundle IDs / Service IDs accepted in Apple identity token aud.
APPLE_CLIENT_IDS=
# Backward-compatible alias still accepted by the backend.
APPLE_CLIENT_ID=

CLICK_PAYMENT_URL=https://my.click.uz/services/pay
CLICK_MERCHANT_ID=
CLICK_MERCHANT_USER_ID=
CLICK_SERVICE_ID=
CLICK_SECRET_KEY=
CLICK_RETURN_URL=
CLICK_DEFAULT_SUBSCRIPTION_DAYS=30
